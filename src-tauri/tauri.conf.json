{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TTMEvolve",
  "version": "0.9.0",
  "identifier": "com.ttmevolve.desktop",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm --prefix ../frontend run dev -- --host 127.0.0.1",
    "beforeBuildCommand": "npm --prefix ../frontend run build"
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://github.com/KingSystemHaiGo/TTMEvolve/releases/latest/download/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "REPLACE_WITH_RELEASE_SIGNING_PUBLIC_KEY",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TTMEvolve",
        "url": "index.html",
        "width": 1600,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 576,
        "resizable": true,
        "dragDropEnabled": false,
        "devtools": true,
        "decorations": false,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "deb", "appimage", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../main.py": "main.py",
      "../core": "core",
      "../agent": "agent",
      "../llm": "llm",
      "../learning": "learning",
      "../server": "server",
      "../memory": "memory",
      "../ecosystem": "ecosystem",
      "../cli": "cli",
      "../config.json": "config.json",
      "../config.example.json": "config.example.json",
      "../requirements.txt": "requirements.txt",
      "../start.bat": "start.bat",
      "../start.sh": "start.sh",
      "../start-tauri.bat": "start-tauri.bat",
      "../start-tauri.sh": "start-tauri.sh"
    },
    "category": "DeveloperTool",
    "shortDescription": "TTMEvolve — Self-evolving TapMaker Agent",
    "longDescription": "TTMEvolve is a desktop Agent workbench for TapTap Maker game development. It brings cloud LLM routing, Plan First, Maker MCP integration, and embedded Python runtime to a single Windows / macOS / Linux app.",
    "homepage": "https://github.com/KingSystemHaiGo/TTMEvolve",
    "publisher": "TTMEvolve Contributors",
    "license": "MIT"
  }
}
