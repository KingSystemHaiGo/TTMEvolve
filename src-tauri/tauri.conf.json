{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TTMEvolve",
  "version": "0.7.0",
  "identifier": "com.ttmevolve.desktop",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TTMEvolve",
        "url": "index.html",
        "width": 1600,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 576,
        "resizable": true,
        "dragDropEnabled": false,
        "devtools": true,
        "decorations": false,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../portable": "portable",
      "../main.py": "main.py",
      "../core": "core",
      "../agent": "agent",
      "../llm": "llm",
      "../learning": "learning",
      "../server": "server",
      "../memory": "memory",
      "../ecosystem": "ecosystem",
      "../cli": "cli",
      "../config.json": "config.json",
      "../config.example.json": "config.example.json",
      "../requirements.txt": "requirements.txt",
      "../start.bat": "start.bat",
      "../start.sh": "start.sh"
    }
  }
}